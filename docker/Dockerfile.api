FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy workspace config needed for path resolution
COPY nx.json tsconfig.base.json ./

# Copy source code
COPY apps/api ./apps/api
COPY libs ./libs

EXPOSE 3001

# Run TypeScript directly for local dev (no build step needed)
CMD ["npx", "ts-node", "-r", "tsconfig-paths/register", "--project", "apps/api/tsconfig.app.json", "apps/api/src/main.ts"]
